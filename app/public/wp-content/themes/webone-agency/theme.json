{
    "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "color": {
            "defaultDuotone": false,
            "defaultGradients": false,
            "defaultPalette": false,
            "palette": [
                {
                    "color": "#0a0a0f",
                    "name": "Base",
                    "slug": "base"
                },
                {
                    "color": "#f8fafc",
                    "name": "Contrast",
                    "slug": "contrast"
                },
                {
                    "color": "#6366f1",
                    "name": "Primary",
                    "slug": "accent-1"
                },
                {
                    "color": "#8b5cf6",
                    "name": "Secondary",
                    "slug": "accent-2"
                },
                {
                    "color": "#22d3ee",
                    "name": "Accent",
                    "slug": "accent-3"
                },
                {
                    "color": "#94a3b8",
                    "name": "Text Secondary",
                    "slug": "accent-4"
                },
                {
                    "color": "#12121a",
                    "name": "Background Alt",
                    "slug": "accent-5"
                },
                {
                    "color": "rgba(99, 102, 241, 0.2)",
                    "name": "Border",
                    "slug": "accent-6"
                }
            ],
            "gradients": [
                {
                    "gradient": "linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #22d3ee 100%)",
                    "name": "Primary Gradient",
                    "slug": "primary-gradient"
                },
                {
                    "gradient": "linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 50%, #16213e 100%)",
                    "name": "Hero Gradient",
                    "slug": "hero-gradient"
                },
                {
                    "gradient": "linear-gradient(180deg, #0a0a0f 0%, #12121a 100%)",
                    "name": "Section Gradient",
                    "slug": "section-gradient"
                }
            ]
        },
        "layout": {
            "contentSize": "800px",
            "wideSize": "1340px"
        },
        "spacing": {
            "defaultSpacingSizes": false,
            "spacingSizes": [
                {
                    "name": "Tiny",
                    "size": "10px",
                    "slug": "20"
                },
                {
                    "name": "X-Small",
                    "size": "20px",
                    "slug": "30"
                },
                {
                    "name": "Small",
                    "size": "30px",
                    "slug": "40"
                },
                {
                    "name": "Regular",
                    "size": "clamp(30px, 5vw, 50px)",
                    "slug": "50"
                },
                {
                    "name": "Large",
                    "size": "clamp(40px, 8vw, 80px)",
                    "slug": "60"
                },
                {
                    "name": "X-Large",
                    "size": "clamp(60px, 10vw, 120px)",
                    "slug": "70"
                },
                {
                    "name": "XX-Large",
                    "size": "clamp(80px, 12vw, 160px)",
                    "slug": "80"
                }
            ],
            "units": [
                "%",
                "px",
                "em",
                "rem",
                "vh",
                "vw"
            ]
        },
        "typography": {
            "writingMode": true,
            "defaultFontSizes": false,
            "fluid": true,
            "fontSizes": [
                {
                    "fluid": false,
                    "name": "Small",
                    "size": "0.875rem",
                    "slug": "small"
                },
                {
                    "fluid": {
                        "max": "1.125rem",
                        "min": "1rem"
                    },
                    "name": "Medium",
                    "size": "1rem",
                    "slug": "medium"
                },
                {
                    "fluid": {
                        "max": "1.375rem",
                        "min": "1.125rem"
                    },
                    "name": "Large",
                    "size": "1.38rem",
                    "slug": "large"
                },
                {
                    "fluid": {
                        "max": "2.25rem",
                        "min": "1.75rem"
                    },
                    "name": "Extra Large",
                    "size": "2rem",
                    "slug": "x-large"
                },
                {
                    "fluid": {
                        "max": "3.5rem",
                        "min": "2.5rem"
                    },
                    "name": "Extra Extra Large",
                    "size": "3rem",
                    "slug": "xx-large"
                },
                {
                    "fluid": {
                        "max": "5rem",
                        "min": "3rem"
                    },
                    "name": "Huge",
                    "size": "4rem",
                    "slug": "huge"
                }
            ],
            "fontFamilies": [
                {
                    "name": "Manrope",
                    "slug": "manrope",
                    "fontFamily": "Manrope, sans-serif",
                    "fontFace": [
                        {
                            "src": [
                                "file:./assets/fonts/manrope/Manrope-VariableFont_wght.woff2"
                            ],
                            "fontWeight": "200 800",
                            "fontStyle": "normal",
                            "fontFamily": "Manrope"
                        }
                    ]
                },
                {
                    "name": "Fira Code",
                    "slug": "fira-code",
                    "fontFamily": "\"Fira Code\", monospace",
                    "fontFace": [
                        {
                            "src": [
                                "file:./assets/fonts/fira-code/FiraCode-VariableFont_wght.woff2"
                            ],
                            "fontWeight": "300 700",
                            "fontStyle": "normal",
                            "fontFamily": "\"Fira Code\""
                        }
                    ]
                }
            ]
        },
        "useRootPaddingAwareAlignments": true
    },
    "styles": {
        "color": {
            "background": "var:preset|color|base",
            "text": "var:preset|color|contrast"
        },
        "spacing": {
            "blockGap": "1.5rem",
            "padding": {
                "left": "var:preset|spacing|50",
                "right": "var:preset|spacing|50"
            }
        },
        "typography": {
            "fontFamily": "var:preset|font-family|manrope",
            "fontSize": "var:preset|font-size|medium",
            "fontWeight": "400",
            "letterSpacing": "-0.02em",
            "lineHeight": "1.6"
        },
        "elements": {
            "button": {
                "border": {
                    "radius": "100px"
                },
                "color": {
                    "background": "var:preset|color|accent-1",
                    "text": "#ffffff"
                },
                ":hover": {
                    "color": {
                        "background": "var:preset|color|accent-2"
                    }
                },
                "spacing": {
                    "padding": {
                        "bottom": "1rem",
                        "left": "2.5rem",
                        "right": "2.5rem",
                        "top": "1rem"
                    }
                },
                "typography": {
                    "fontSize": "var:preset|font-size|medium",
                    "fontWeight": "600"
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "var:preset|font-size|huge",
                    "fontWeight": "700",
                    "lineHeight": "1.1"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var:preset|font-size|xx-large",
                    "fontWeight": "700",
                    "lineHeight": "1.15"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var:preset|font-size|x-large",
                    "fontWeight": "600"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "var:preset|font-size|large",
                    "fontWeight": "600"
                }
            },
            "h5": {
                "typography": {
                    "fontSize": "var:preset|font-size|medium",
                    "fontWeight": "600",
                    "letterSpacing": "0.5px"
                }
            },
            "h6": {
                "typography": {
                    "fontSize": "var:preset|font-size|small",
                    "fontWeight": "700",
                    "letterSpacing": "2px",
                    "textTransform": "uppercase"
                }
            },
            "heading": {
                "color": {
                    "text": "var:preset|color|contrast"
                },
                "typography": {
                    "fontWeight": "600",
                    "lineHeight": "1.2",
                    "letterSpacing": "-0.02em"
                }
            },
            "link": {
                "color": {
                    "text": "var:preset|color|accent-1"
                },
                ":hover": {
                    "color": {
                        "text": "var:preset|color|accent-3"
                    },
                    "typography": {
                        "textDecoration": "none"
                    }
                }
            }
        },
        "blocks": {
            "core/navigation": {
                "typography": {
                    "fontSize": "var:preset|font-size|medium",
                    "fontWeight": "500"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var:preset|color|contrast"
                        },
                        ":hover": {
                            "color": {
                                "text": "var:preset|color|accent-1"
                            }
                        }
                    }
                }
            },
            "core/site-title": {
                "typography": {
                    "fontSize": "var:preset|font-size|large",
                    "fontWeight": "700",
                    "letterSpacing": "-0.5px"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var:preset|color|contrast"
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                }
            },
            "core/paragraph": {
                "color": {
                    "text": "var:preset|color|accent-4"
                }
            },
            "core/group": {
                "spacing": {
                    "padding": {
                        "top": "0",
                        "bottom": "0"
                    }
                }
            }
        }
    },
    "templateParts": [
        {
            "area": "header",
            "name": "header",
            "title": "Header"
        },
        {
            "area": "footer",
            "name": "footer",
            "title": "Footer"
        }
    ],
    "customTemplates": [
        {
            "name": "front-page",
            "postTypes": [
                "page"
            ],
            "title": "Agency Homepage"
        }
    ]
}